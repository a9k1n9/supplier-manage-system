    "from openpyxl import load_workbook\n",
    "\n",
    "import os\n",
    "file_path = r'C:\\Users\\lenovo\\Desktop\\技术运营部供应商名录2026.6.18.xlsx'\n",
    "# 加载工作簿\n",
    "wb = load_workbook(file_path, read_only=True)\n",
    "\n",
    "# 1. 区分可见与隐藏工作表\n",
    "visible_sheets = []\n",
    "hidden_sheets = []\n",
    "for name in wb.sheetnames:\n",
    "    state = wb[name].sheet_state\n",
    "    if state == 'visible':\n",
    "        visible_sheets.append(name)\n",
    "    else:\n",
    "        hidden_sheets.append((name, state))\n",
    "\n",
    "print(f\"可见工作表: {visible_sheets}\")\n",
    "print(f\"隐藏工作表: {hidden_sheets}\")\n",
    "\n",
    "# 2. 逐一预览每个可见工作表的表头和前10行数据\n",
    "for sheet_name in visible_sheets:\n",
    "    ws = wb[sheet_name]\n",
    "    print(f\"\\n===== 正在预览可见工作表：'{sheet_name}' =====\")\n",
    "    # 读取表头\n",
    "    headers = [cell.value for cell in next(ws.iter_rows(min_row=1, max_row=1))]\n",
    "    print(f\"表头: {headers}\")\n",
    "    # 读取前10行数据\n",
    "    for i, row in enumerate(ws.iter_rows(min_row=2, max_row=min(11, ws.max_row), values_only=True)):\n",
    "        print(f\"第{i+1}行数据: {row}\")\n",
    "\n",
    "wb.close()"
   ]
